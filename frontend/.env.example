# Copy this file to `.env.local` and adjust values as needed.
# Variables prefixed with NEXT_PUBLIC_ are inlined at build time.

# Show the "Recommended Content" section in the chapter reader (default: disabled).
# NEXT_PUBLIC_READER_RECOMMENDED_CONTENT=true

# ── Supabase Auth ──────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── Backend API ────────────────────────────────────────────────────────────────
# URL of the VeoBible API (Cloudflare Worker)
NEXT_PUBLIC_API_URL=https://api.veobible.com
