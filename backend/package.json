{
  "name": "veobible-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply veobible-prod",
    "db:migrate:local": "wrangler d1 migrations apply veobible-prod --local",
    "db:migration:new": "wrangler d1 migrations create veobible-prod"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "typescript": "^5.4.5",
    "wrangler": "^4.100.0"
  }
}
